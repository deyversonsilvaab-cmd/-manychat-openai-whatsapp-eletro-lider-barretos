{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 60
    },
    "api/health.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    }
  ]
}